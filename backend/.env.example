# ЧитАИ — образец .env. Скопируйте в backend/.env и заполните своими ключами.
# НЕ коммитить реальный .env (он в .gitignore).

# ============ YandexGPT (Yandex AI Studio) ============
# 1. Создайте API-ключ: https://console.cloud.yandex.ru/folders/<folder>/iam/api-keys
# 2. Выдайте сервисному аккаунту роль `ai.languageModels.user` на каталог.
# 3. Подставьте FOLDER_ID каталога (виден в URL консоли).
YANDEX_GPT_API_KEY=AQVN_replace_me
YANDEX_GPT_FOLDER_ID=b1g_replace_me
# Допустимо: yandexgpt/latest, yandexgpt-lite/latest, yandexgpt/rc, или полный gpt://...
YANDEX_GPT_MODEL=yandexgpt/latest

# ============ GigaChat (Сбер) ============
# 1. Регистрация: https://developers.sber.ru/portal/gigachat-api
# 2. Создайте «Личное пространство» → API-ключ → значение «Authorization key» — это base64.
GIGACHAT_AUTHORIZATION_KEY=base64_authorization_key_replace_me
GIGACHAT_CLIENT_ID=uuid_client_id_replace_me
# Для физлиц: GIGACHAT_API_PERS. Для юрлиц: GIGACHAT_API_CORP.
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модели: GigaChat, GigaChat-Pro, GigaChat-Max, GigaChat-2, GigaChat-2-Pro
GIGACHAT_MODEL=GigaChat-Max

# ============ LLM-роутер ============
# Какой провайдер пробовать первым; второй идёт в fallback. yandex | gigachat
LLM_PRIMARY=yandex
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
